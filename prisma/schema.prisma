generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Session {
  id           String        @id @default(cuid())
  code         String        @unique
  name         String
  createdAt    DateTime      @default(now())
  participants Participant[]
  topics       Topic[]
}

model Participant {
  id        String   @id @default(cuid())
  sessionId String
  name      String
  token     String   @unique
  isHost    Boolean  @default(false)
  joinedAt  DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  votes     Vote[]

  @@index([sessionId])
}

model Topic {
  id          String       @id @default(cuid())
  sessionId   String
  title       String
  description String       @default("")
  status      String       @default("pending") // pending | voting | revealed | closed
  order       Int
  round       Int          @default(1)
  session     Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  votes       Vote[]
  actionItems ActionItem[]

  @@index([sessionId])
}

model Vote {
  id            String      @id @default(cuid())
  topicId       String
  participantId String
  value         Int
  round         Int
  createdAt     DateTime    @default(now())
  topic         Topic       @relation(fields: [topicId], references: [id], onDelete: Cascade)
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([topicId, participantId, round])
  @@index([topicId])
}

model ActionItem {
  id        String   @id @default(cuid())
  topicId   String
  text      String
  createdAt DateTime @default(now())
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}
